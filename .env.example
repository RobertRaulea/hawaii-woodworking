# Rename this file to .env and fill in your credentials
# Get your Convex deployment URL from `npx convex dev`

# Convex Configuration (Required)
# For development: Use your dev deployment URL
# For production seeding: Temporarily switch to production URL
VITE_CONVEX_URL=https://your-project.convex.cloud

# Clerk Configuration (Required for admin authentication)
# Get your publishable key from: https://dashboard.clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# Stripe Configuration (Required for payment processing)
# Get your secret key from: https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) for development
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# --- Convex Dashboard Environment Variables ---
# Set these in the Convex dashboard (Settings → Environment Variables):
# CLERK_JWT_ISSUER_DOMAIN=https://your-clerk-instance.clerk.accounts.dev
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# --- Email & Invoice Automation (Required for order notifications) ---
# Resend API Key - Get from: https://resend.com/api-keys
RESEND_API_KEY=re_bAXoq3hj_NhxxoQK2CrMLu5uhzrVv1kBq

# Admin notification email address
ADMIN_EMAIL=hawaiisibiu@gmail.com

# Verified sender email (must be verified in Resend dashboard)
RESEND_FROM_EMAIL=orders@hawaiiproducts.ro

# Oblio API Credentials - Get from: Oblio Settings → API
# OBLIO_API_EMAIL=your_api_email@example.com
# OBLIO_API_SECRET=your_api_secret_token
# OBLIO_API_CIF=your_company_cif
