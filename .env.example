# Rename this file to .env and fill in your credentials
# Get your Convex deployment URL from `npx convex dev`

# Convex Configuration (Required)
VITE_CONVEX_URL=https://your-project.convex.cloud

# Stripe Configuration (Required for payment processing)
# Get your secret key from: https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) for development
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
